# ---- PostgreSQL ----
POSTGRES_USER=adinsight
POSTGRES_PASSWORD=adinsight_pw
POSTGRES_DB=adinsight
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend 連線字串(由上面組成;compose 內服務名為 db)
DATABASE_URL=postgresql+psycopg2://adinsight:adinsight_pw@db:5432/adinsight

# ---- Gemini ----
# 到 https://aistudio.google.com 免費取得
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- ETL 設定 ----
# Meta 來源 USD→TWD 固定匯率(R4,MVP 取捨)
USD_TWD_RATE=32.0
# Mock 歷史天數(D5 資料量;3 來源 x 8 活動 x N 天)
MOCK_HISTORY_DAYS=90

# ---- 前端 ----
# 後端允許的 CORS 來源(R1)
FRONTEND_ORIGIN=http://localhost:5173
# 前端打後端的 base url
VITE_API_BASE=http://localhost:8000
